# Research Radar configuration.
# Copy this file to .env and replace placeholder values before real use.

# Web server. Keep APP_HOST at 127.0.0.1 unless protected by a VPN, SSH tunnel,
# or HTTPS reverse proxy with authentication.
APP_HOST=127.0.0.1
APP_PORT=8000
APP_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
SESSION_HTTPS_ONLY=false
PUBLIC_BASE_URL=http://127.0.0.1:8000

# Default development login password is: research-radar
# Replace this with: research-radar hash-password
ADMIN_PASSWORD_HASH=pbkdf2_sha256$260000$lxPF9IATsBF4N4qL3cz5aw$X6hD4PkQ7yPbDNk9hwa2LVrGdi6HKYwmi2RGVT2HEMk

# Storage and config paths.
DATABASE_URL=sqlite:///./data/research_radar.db
PROFILE_PATH=config/profile.yaml
RSS_FEEDS_PATH=config/rss_feeds.yaml

# Ingestion.
ARXIV_CATEGORIES=cs.AI,cs.CL,cs.LG,cs.CV,stat.ML
ARXIV_MAX_RESULTS=75
ARXIV_DAYS_BACK=14
HTTP_TIMEOUT_SECONDS=25

# Digest behavior.
DAILY_MAX_PAPERS=10
WEEKLY_DISCOVERY_WINDOW_DAYS=180

# Notion watchlist. Leave blank until configured.
NOTION_TOKEN=
NOTION_PAGE_IDS=
NOTION_DATABASE_ID=

# Semantic Scholar enrichment. Optional for MVP.
SEMANTIC_SCHOLAR_API_KEY=

# OpenAlex enrichment. Optional for MVP.
OPENALEX_EMAIL=
OPENALEX_API_KEY=
OPENALEX_TOKEN=

# Future read-only X/Twitter integration placeholder.
X_API_KEY=
X_BEARER_TOKEN=
X_LIST_IDS=

# LLM provider.
# mock is deterministic and always available.
# ollama uses OLLAMA_BASE_URL + OLLAMA_MODEL.
# openai-compatible uses OPENAI_BASE_URL + OPENAI_API_KEY + OPENAI_MODEL.
LLM_PROVIDER=mock
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=
OPENAI_BASE_URL=http://127.0.0.1:8001/v1
OPENAI_API_KEY=
OPENAI_MODEL=

# SMTP email. Leave blank to skip sending without failing digest generation.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
DIGEST_TO_EMAIL=
